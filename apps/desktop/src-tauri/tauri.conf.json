{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CupCat",
  "version": "1.7.16",
  "identifier": "io.cupcat.app",
  "build": {
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CupCat",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/cupcat-bridge"],
    "resources": ["sidecars/*", "sidecars/piper", "sidecars/diarize", "sidecars/separate", "sidecars/faces"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "template": "./nsis/installer.nsi"
      }
    }
  }
}
